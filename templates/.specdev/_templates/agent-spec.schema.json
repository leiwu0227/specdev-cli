{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["description", "input", "output", "runners"],
  "properties": {
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "input": {
      "type": "object"
    },
    "output": {
      "type": "object",
      "required": ["schema", "format"],
      "properties": {
        "schema": {
          "type": "string",
          "minLength": 1
        },
        "format": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "model": {
      "type": ["string", "object", "null"]
    },
    "runners": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["command", "args", "prompt", "timeout_ms"],
        "properties": {
          "command": {
            "type": "string",
            "minLength": 1
          },
          "args": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "prompt": {
            "type": "object",
            "required": ["mode"],
            "properties": {
              "mode": {
                "enum": ["append_arg", "flag_arg", "stdin"]
              },
              "flag": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "stream_json": {
            "type": "boolean"
          },
          "timeout_ms": {
            "type": "integer",
            "minimum": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}
