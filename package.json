{
  "name": "@specdev/cli",
  "version": "0.0.4",
  "releaseDate": "2026-05-11",
  "description": "CLI to initialize SpecDev workflow system",
  "type": "module",
  "bin": {
    "specdev": "./bin/specdev.js"
  },
  "files": [
    "bin/",
    "src/",
    "templates/",
    "hooks/",
    "specdev.assignment-schema.json"
  ],
  "scripts": {
    "test": "npm run test:init && npm run test:assignment && npm run test:workflow-contract-drift && npm run test:update && npm run test:knowledge && npm run test:workflow-agent && npm run test:approve-phase && npm run test:checkpoints && npm run test:reviewloop-command && npm run test:cleanup",
    "test:init": "node ./tests/test-init.js",
    "test:assignment": "node ./tests/test-assignment.js",
    "test:workflow-contract-drift": "node ./tests/test-workflow-contract-drift.js",
    "test:update": "node ./tests/test-update.js",
    "test:knowledge": "node ./tests/test-knowledge.js",
    "test:workflow-agent": "node ./tests/test-workflow-agent.js",
    "test:approve-phase": "node ./tests/test-approve-phase.js",
    "test:checkpoints": "node ./tests/test-checkpoints.js",
    "test:reviewloop-command": "node ./tests/test-reviewloop-command.js",
    "test:cleanup": "rm -rf ./tests/test-init-output ./test-assignment-output ./tests/test-assignment-schema-output ./tests/test-update-output ./tests/test-knowledge-output ./tests/test-workflow-agent-output ./tests/test-approve-phase-output ./tests/test-reviewloop-command-output ./tests/test-checkpoints-output",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "preversion": "sed -i \"s/\\\"releaseDate\\\": \\\"[0-9-]*\\\"/\\\"releaseDate\\\": \\\"$(date +%Y-%m-%d)\\\"/\" package.json",
    "release": "npm version patch && npm publish",
    "release:minor": "npm version minor && npm publish",
    "release:major": "npm version major && npm publish"
  },
  "keywords": [
    "specdev",
    "workflow",
    "cli",
    "development",
    "markdown",
    "project-structure"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "ajv": "^8.20.0",
    "fs-extra": "^11.2.0",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "prettier": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
