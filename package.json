{
  "name": "@specdev/cli",
  "version": "0.0.4",
  "releaseDate": "2026-05-13",
  "description": "CLI to initialize SpecDev workflow system",
  "type": "module",
  "bin": {
    "specdev": "./bin/specdev.js"
  },
  "files": [
    "bin/",
    "src/",
    "templates/",
    "hooks/",
    "specdev.assignment-schema.json"
  ],
  "scripts": {
    "test": "node ./tests/test-workflow-contract-drift.js && node ./tests/test-session-state-protocol.js && node ./tests/test-manifest-as-truth.js && npm run test:cleanup",
    "test:workflow-contract-drift": "node ./tests/test-workflow-contract-drift.js",
    "test:session-state-protocol": "node ./tests/test-session-state-protocol.js",
    "test:manifest-as-truth": "node ./tests/test-manifest-as-truth.js",
    "test:cleanup": "rm -rf ./tests/test-*-output ./test-assignment-output",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "preversion": "sed -i \"s/\\\"releaseDate\\\": \\\"[0-9-]*\\\"/\\\"releaseDate\\\": \\\"$(date +%Y-%m-%d)\\\"/\" package.json",
    "release": "npm version patch && npm publish",
    "release:minor": "npm version minor && npm publish",
    "release:major": "npm version major && npm publish"
  },
  "keywords": [
    "specdev",
    "workflow",
    "cli",
    "development",
    "markdown",
    "project-structure"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "ajv": "^8.20.0",
    "fs-extra": "^11.2.0",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "prettier": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
