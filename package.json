{
  "name": "@specdev/cli",
  "version": "0.0.4",
  "releaseDate": "2026-05-08",
  "description": "CLI to initialize SpecDev workflow system",
  "type": "module",
  "bin": {
    "specdev": "./bin/specdev.js"
  },
  "files": [
    "bin/",
    "src/",
    "templates/",
    "hooks/",
    "specdev.assignment-schema.json"
  ],
  "scripts": {
    "test": "npm run test:init && npm run test:scan && npm run test:assignment && npm run test:utils && npm run test:scripts && npm run test:workflow && npm run test:skills && npm run test:update && npm run test:memory && npm run test:knowledge && npm run test:context && npm run test:json-simple && npm run test:json-medium && npm run test:hook && npm run test:distill && npm run test:reviewloop && npm run test:reviewloop-command && npm run test:checkpoints && npm run test:cleanup",
    "test:init": "node ./tests/test-init.js",
    "test:scan": "node ./tests/test-scan.js",
    "test:assignment": "node ./tests/test-assignment.js",
    "test:utils": "node ./tests/test-utils.js",
    "test:scripts": "node ./tests/test-scripts.js",
    "test:workflow": "node ./tests/test-workflow.js",
    "test:skills": "node ./tests/test-skills.js",
    "test:update": "node ./tests/test-update.js",
    "test:memory": "node ./tests/test-memory.js",
    "test:knowledge": "node ./tests/test-knowledge.js",
    "test:context": "node ./tests/test-context.js",
    "test:json-simple": "node ./tests/test-json-simple.js",
    "test:json-medium": "node ./tests/test-json-medium.js",
    "test:hook": "node ./tests/test-hook.js",
    "test:distill": "node ./tests/test-distill.js",
    "test:reviewloop": "node ./tests/test-reviewloop.js",
    "test:reviewloop-command": "node ./tests/test-reviewloop-command.js",
    "test:checkpoints": "node ./tests/test-checkpoints.js",
    "test:cleanup": "rm -rf ./tests/test-init-output ./test-scan-output ./test-assignment-output ./tests/test-assignment-schema-output ./tests/test-utils-output ./tests/test-scripts-output ./tests/test-scripts-output-worktrees ./test-workflow-output ./tests/test-skills-output ./tests/test-update-output ./tests/test-memory-output ./tests/test-knowledge-output ./tests/test-context-output ./tests/test-json-simple-output ./tests/test-json-medium-output ./tests/test-hook-output ./tests/test-distill-output ./tests/test-reviewloop-output ./tests/test-reviewloop-command-output ./tests/test-checkpoints-output",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "preversion": "sed -i \"s/\\\"releaseDate\\\": \\\"[0-9-]*\\\"/\\\"releaseDate\\\": \\\"$(date +%Y-%m-%d)\\\"/\" package.json",
    "release": "npm version patch && npm publish",
    "release:minor": "npm version minor && npm publish",
    "release:major": "npm version major && npm publish"
  },
  "keywords": [
    "specdev",
    "workflow",
    "cli",
    "development",
    "markdown",
    "project-structure"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "prettier": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
